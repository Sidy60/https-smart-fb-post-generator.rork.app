{
  "expo": {
    "name": "posts-generatorx",
    "slug": "posts-generatorx",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "postsgeneratorx",
    "userInterfaceStyle": "automatic",

    "android": {
      "package": "com.sidy6072.postsgeneratorx",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      }
    },

    "plugins": [
      "expo-router",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-5350081816144613~8292166017"
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    }
  }
}